{
  "_comment": "Claude Desktop / Claude Code MCP client configuration. Copy relevant sections into ~/.config/claude/claude_desktop_config.json (Mac) or %APPDATA%\\Claude\\claude_desktop_config.json (Windows).",
  "mcpServers": {
    "revolis-crm": {
      "command": "node",
      "args": ["C:\\RealitkaAI\\packages\\mcp-crm\\dist\\server.js"],
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_SERVICE_KEY": "${SUPABASE_SERVICE_KEY}",
        "NODE_ENV": "development"
      }
    },
    "revolis-comm": {
      "command": "node",
      "args": ["C:\\RealitkaAI\\packages\\mcp-comm\\dist\\server.js"],
      "env": {
        "RESEND_API_KEY": "${RESEND_API_KEY}",
        "TWILIO_ACCOUNT_SID": "${TWILIO_ACCOUNT_SID}",
        "TWILIO_AUTH_TOKEN": "${TWILIO_AUTH_TOKEN}",
        "TWILIO_FROM_NUMBER": "${TWILIO_FROM_NUMBER}"
      }
    },
    "revolis-calendar": {
      "command": "node",
      "args": ["C:\\RealitkaAI\\packages\\mcp-calendar\\dist\\server.js"],
      "env": {
        "GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON": "${GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON}"
      }
    },
    "revolis-telephony": {
      "command": "node",
      "args": ["C:\\RealitkaAI\\packages\\mcp-telephony\\dist\\server.js"],
      "env": {
        "TWILIO_ACCOUNT_SID": "${TWILIO_ACCOUNT_SID}",
        "TWILIO_AUTH_TOKEN": "${TWILIO_AUTH_TOKEN}",
        "TWILIO_FROM_NUMBER": "${TWILIO_FROM_NUMBER}"
      }
    }
  }
}
