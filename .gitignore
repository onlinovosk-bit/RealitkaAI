# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Backup files — never commit secrets
backups/
*.bak
*.env.local.bak

# Dependencies (any directory in the monorepo)
node_modules/

# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class

# testing
coverage/
playwright-report/
test-results/

# next.js / bundler outputs
.next/
out/
build/
dist/

# Logs (generic + package-manager)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# misc
.DS_Store
*.pem

# debug
.pnp
.pnp.js

# Supabase CLI / local tooling caches
**/.temp/

# local env files (tracked examples stay allowed below)
.env
.env*.local
!.env.example
!.env.*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
