# Predloha pre produkčné prostredie (bez reálnych tajomstiev).
#
# Ako použiť:
# • Vercel: skopíruj kľúče do Project → Settings → Environment Variables → Production
# • Lokálne `next start` / produkčný build: skopíruj na .env.production (súbor je gitignored)
#
# Pozri tiež .env.local.example pre dev.

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only (cron, service role skripty, admin operácie)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── App URL ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.revolis.ai

# ── Auth / cron ───────────────────────────────────────────────
CRON_SECRET=generate-with-openssl-rand-hex-32

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxx
OUTREACH_FROM_EMAIL=Revolis <onboarding@mg.revolis.ai>

# ── Billing (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_SCALE=price_xxx

APP_TRIAL_DAYS=14
APP_GRACE_DAYS=7

SALES_CALENDAR_BOOKING_URL=https://calendly.com/your-team/demo

# ── AI (Morning Brief, triage, follow-up) ───────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# ── Architect / AI jobs (voliteľné) ───────────────────────────
# TRIAGE_LEAD_LIMIT=200
# TRIAGE_LOCK_STALE_MS=2700000
# FOLLOWUP_STALE_DAYS=5
# FOLLOWUP_MODE=draft
# FOLLOWUP_SWEEP_LIMIT=24
# FOLLOWUP_COOLDOWN_DAYS=7
# FOLLOWUP_MAX_AI_PER_LEAD=12
# AI_JOBS_BATCH_SIZE=15

# Voliteľné: SMS (Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=

# ── Web Push (VAPID) ─────────────────────────────────────────
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BK...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:support@revolis.ai
