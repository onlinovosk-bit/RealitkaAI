{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/pulse",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/bri-snapshot",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/morning-brief",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/lead-ai-triage",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/follow-up-sweep",
      "schedule": "0 22 * * *"
    }
  ]
}
