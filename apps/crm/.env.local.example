# Skopíruj na .env.local a vyplň hodnoty.
# ─────────────────────────────────────────────────────────────
# VERCEL (Production / Preview)
# Súbor .env.local sa na server neposiela. Každú kľúčovú premennú
# nastav aj v: Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Verejná URL nasadenej appky (odkazy v mailoch, billing return URL)
NEXT_PUBLIC_APP_URL=https://app.revolis.ai

# Transakčné emaily z CRM (Resend): playbook potvrdenia, outreach, atď.
RESEND_API_KEY=re_xxxxxxx
OUTREACH_FROM_EMAIL=Revolis <onboarding@mg.revolis.ai>

# Voliteľné: SMS z API (Twilio) — inak playbook použije sms: odkaz
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=

# Legal / support formuláre (viac v docs/email-delivery-setup.md)
# EMAIL_PROVIDER=RESEND
# LEGAL_INBOX=legal@revolis.ai
# SUPPORT_INBOX=support@revolis.ai

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_SCALE=price_xxx

APP_TRIAL_DAYS=14
APP_GRACE_DAYS=7

SALES_CALENDAR_BOOKING_URL=https://calendly.com/your-team/demo
