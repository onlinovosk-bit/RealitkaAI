# Skopíruj na .env.local a vyplň hodnoty.
# ─────────────────────────────────────────────────────────────
# VERCEL (Production / Preview)
# Súbor .env.local sa na server neposiela. Každú kľúčovú premennú
# nastav aj v: Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Verejná URL nasadenej appky (odkazy v mailoch, billing return URL)
NEXT_PUBLIC_APP_URL=https://app.revolis.ai

# Transakčné emaily z CRM (Resend): playbook potvrdenia, outreach, atď.
RESEND_API_KEY=re_xxxxxxx
OUTREACH_FROM_EMAIL=Revolis <onboarding@mg.revolis.ai>

# Voliteľné: SMS z API (Twilio) — inak playbook použije sms: odkaz
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=

# Legal / support formuláre (viac v docs/email-delivery-setup.md)
# EMAIL_PROVIDER=RESEND
# LEGAL_INBOX=legal@revolis.ai
# SUPPORT_INBOX=support@revolis.ai

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_SCALE=price_xxx

# Pricing stack v1.0 — seat + cockpit + credit top-up (Andy: Stripe Dashboard)
STRIPE_PRICE_SOLO_SEAT=price_xxx
STRIPE_PRICE_TEAM_SEAT=price_xxx
STRIPE_PRICE_OFFICE_SEAT=price_xxx
STRIPE_PRICE_OWNER_COCKPIT=price_xxx
STRIPE_PRICE_OWNER_COCKPIT_FOUNDER=price_xxx
# STRIPE_PRICE_OWNER_COCKPIT_PRO=price_xxx  # disabled until legal + product ready
STRIPE_PRICE_CREDITS_START=price_xxx
STRIPE_PRICE_CREDITS_RAST=price_xxx
STRIPE_PRICE_CREDITS_PRO=price_xxx
STRIPE_PRICE_CREDITS_MEGA=price_xxx

APP_TRIAL_DAYS=14
APP_GRACE_DAYS=7

SALES_CALENDAR_BOOKING_URL=https://calendly.com/your-team/demo

# Demo Ops (Calendly webhook + brief/recap crons)
# CALENDLY_WEBHOOK_SECRET=whsec_...   # Calendly webhook signing key
# DEMO_OPS_ANDY_EMAIL=andy@revolis.ai # Kam chodia pre-demo briefy a recap drafty

# ── Morning Brief (Feature #3) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# 3-step onboarding wizard (default OFF). Entry: /post-login or /get-started
# ONBOARDING_WIZARD_ENABLED=true

# Architect W1/W2 (voliteľné overrides)
# TRIAGE_LEAD_LIMIT=200
# TRIAGE_AGENCY_ID=<uuid>  # voliteľné: triáž len pre jednu RK (backfill Smolko)
# FOLLOWUP_STALE_DAYS=5
# FOLLOWUP_MODE=draft
# FOLLOWUP_SWEEP_LIMIT=24
# FOLLOWUP_COOLDOWN_DAYS=7
# FOLLOWUP_MAX_AI_PER_LEAD=12

RESEND_API_KEY=re_...
CRON_SECRET=generate-with-openssl-rand-hex-32

# Stealth Recruiter: false on prod so /scan reads DB only (no demo fallback)
# STEALTH_RECRUITER_DEMO_MODE=false
# STEALTH_RECRUITER_AGENCY_SLUG=reality-smolko
# STEALTH_RECRUITER_DEFAULT_AGENCY_ID=11111111-1111-1111-1111-111111111111

# Web Push VAPID keys — generate with:
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BK...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:support@revolis.ai

NEXT_PUBLIC_APP_URL=https://app.revolis.ai
