PORT=4100
DATABASE_URL=postgresql://revolis:devpassword@localhost:5433/revolis_ri
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# Realvia API (Phase 0 — TBD after Seliga answers)
REALVIA_BASE_URL=https://dev.realvia.sk
REALVIA_API_KEY=
# REALVIA_CLIENT_CERT=  (if mTLS required — Q4 from Seliga)
# REALVIA_CLIENT_KEY=

# Object storage — raw snapshots (S3-compatible)
OBJECT_STORE_TYPE=local         # local | s3 | r2
OBJECT_STORE_BUCKET=realvia-raw-snapshots
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
# R2_ACCOUNT_ID=               (if Cloudflare R2)
LOCAL_SNAPSHOT_DIR=./snapshots  # used when OBJECT_STORE_TYPE=local

# Cadence (minutes)
CADENCE_DEFAULT=15
CADENCE_BUSINESS=5
CADENCE_OVERNIGHT=60
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
BUSINESS_TZ=Europe/Bratislava

# Reliability
CIRCUIT_BREAKER_THRESHOLD=10   # consecutive failures before open
MAX_RETRY_ATTEMPTS=5

# Outbox → NATS (Phase 4 — stub until NATS is provisioned)
NATS_URL=
